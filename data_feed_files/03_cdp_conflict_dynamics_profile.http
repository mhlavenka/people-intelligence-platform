### Conflict Dynamics Profile — Individual (CDP-I)
### instrumentId: CDP-I | instrumentVersion: 2003
### level_of_analysis: individual | scoring.method: normative | rater_type: self
### Changes from v1:
###   - scoring.subscales normalized from nested object to string[]
###   - Subscale detail (items, clusters, valence) moved to scoring.subscale_config
###   - rater_pool: null kept (field now in model schema)
###   - scale_range.labels changed to keyed Record<string, string> format
###   - Dropped: scoring.unit (redundant with level_of_analysis)

POST http://localhost:3030/api/surveys/templates
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2OWM5MzUyZmYxMmJjMjc3NzBiYTNlZTciLCJvcmdhbml6YXRpb25JZCI6IjY5YzkzNTJmZjEyYmMyNzc3MGJhM2VlNSIsInJvbGUiOiJhZG1pbiIsImVtYWlsIjoiYWRtaW5AaGVsZW5hY29hY2hpbmcuY29tIiwiaWF0IjoxNzc1NDc3MDcwLCJleHAiOjE3NzU0Nzc5NzB9.Bu65b7nGLE4u4bfc_dcx_VO2bryJsKDI_g5rcr_d4dU

{
  "moduleType": "conflict",
  "instrumentId": "CDP-I",
  "instrumentVersion": "2003",
  "title": "Conflict Dynamics Profile — Individual (CDP-I)",
  "description": "Measures both constructive and destructive conflict behaviors across hot (active/escalating) and cool (passive/de-escalating) dimensions. The CDP is the only major validated instrument to directly assess destructive behaviors such as demeaning others and retaliating.",
  "level_of_analysis": "individual",
  "rater_type": "self",
  "rater_pool": null,
  "scoring": {
    "method": "normative",
    "subscales": ["active_constructive", "passive_constructive", "active_destructive", "passive_destructive"],
    "subscale_config": {
      "active_constructive": {
        "behavior_temperature": "hot",
        "valence": "constructive",
        "clusters": ["perspective_taking", "creating_solutions", "expressing_emotions", "reaching_out"],
        "description": "Active, escalation-aware behaviors that constructively engage the conflict."
      },
      "passive_constructive": {
        "behavior_temperature": "cool",
        "valence": "constructive",
        "clusters": ["reflective_thinking", "delay_responding", "adapting"],
        "description": "Measured, de-escalating behaviors that constructively manage conflict tempo."
      },
      "active_destructive": {
        "behavior_temperature": "hot",
        "valence": "destructive",
        "clusters": ["winning_at_all_costs", "displaying_anger", "demeaning_others", "retaliating"],
        "description": "Active, escalating behaviors that damage relationships and outcomes."
      },
      "passive_destructive": {
        "behavior_temperature": "cool",
        "valence": "destructive",
        "clusters": ["avoiding_conflict", "yielding", "hiding_emotions", "self_criticizing"],
        "description": "Passive behaviors that avoid engagement in ways that worsen conflict over time."
      }
    },
    "score_range_per_subscale": { "min": 1, "max": 6 },
    "note": "Score each cluster separately as a mean. Do not collapse into a single conflict score."
  },
  "instructions": "Think about how you behave when you are in conflict or experiencing disagreement at work. Using the 1–6 scale, indicate how often you engage in each of the following behaviors. 1 = Never, 6 = Always.",
  "questions": [

    { "id": "q1",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "perspective_taking", "category": "conflict_behavior",
      "text": "Try to look at the conflict from the other person's perspective.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q2",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "perspective_taking", "category": "conflict_behavior",
      "text": "Consider the other person's point of view before deciding what to do.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q3",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "perspective_taking", "category": "conflict_behavior",
      "text": "Put myself in the other person's position to understand how they see the situation.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q4",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "creating_solutions", "category": "conflict_behavior",
      "text": "Try to think of creative solutions to the conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q5",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "creating_solutions", "category": "conflict_behavior",
      "text": "Generate a number of possible options before deciding what to do about the conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q6",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "creating_solutions", "category": "conflict_behavior",
      "text": "Look for new solutions that meet the needs of everyone involved.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q7",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "expressing_emotions", "category": "conflict_behavior",
      "text": "Tell the other person how I am feeling about the situation.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q8",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "expressing_emotions", "category": "conflict_behavior",
      "text": "Express my feelings openly and directly.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q9",  "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "reaching_out", "category": "conflict_behavior",
      "text": "Reach out to the other person even after a difficult exchange.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q10", "type": "scale", "subscale": "active_constructive",
      "behavior_temperature": "hot", "behavior_cluster": "reaching_out", "category": "conflict_behavior",
      "text": "Initiate reconciliation after a disagreement.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q11", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "reflective_thinking", "category": "conflict_behavior",
      "text": "Step back from the situation and think carefully before responding.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q12", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "reflective_thinking", "category": "conflict_behavior",
      "text": "Pause and reflect before reacting to a conflict situation.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q13", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "delay_responding", "category": "conflict_behavior",
      "text": "Wait for a better time before dealing with a conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q14", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "delay_responding", "category": "conflict_behavior",
      "text": "Allow time to pass before returning to a difficult issue.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q15", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "adapting", "category": "conflict_behavior",
      "text": "Change my approach to the conflict based on how the situation evolves.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q16", "type": "scale", "subscale": "passive_constructive",
      "behavior_temperature": "cool", "behavior_cluster": "adapting", "category": "conflict_behavior",
      "text": "Adjust my strategy as I learn more about the other person's concerns.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q17", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "winning_at_all_costs", "category": "conflict_behavior",
      "text": "Do whatever it takes to win in a conflict situation.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q18", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "winning_at_all_costs", "category": "conflict_behavior",
      "text": "Try to outmaneuver the other person in a conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q19", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "displaying_anger", "category": "conflict_behavior",
      "text": "Raise my voice or show visible frustration during a conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q20", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "displaying_anger", "category": "conflict_behavior",
      "text": "Let my anger show when I am in a conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q21", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "demeaning_others", "category": "conflict_behavior",
      "text": "Belittle the other person's ideas or positions.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q22", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "demeaning_others", "category": "conflict_behavior",
      "text": "Dismiss the other person's concerns as unimportant.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q23", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "retaliating", "category": "conflict_behavior",
      "text": "Get back at the other person when I feel wronged.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q24", "type": "scale", "subscale": "active_destructive",
      "behavior_temperature": "hot", "behavior_cluster": "retaliating", "category": "conflict_behavior",
      "text": "Deliberately make things difficult for someone who has frustrated me.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q25", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "avoiding_conflict", "category": "conflict_behavior",
      "text": "Walk away from a conflict rather than deal with it.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q26", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "avoiding_conflict", "category": "conflict_behavior",
      "text": "Put off dealing with a conflict as long as possible.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q27", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "yielding", "category": "conflict_behavior",
      "text": "Give in to the other person's demands just to end the conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q28", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "yielding", "category": "conflict_behavior",
      "text": "Concede my position without really believing the other person is right.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q29", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "hiding_emotions", "category": "conflict_behavior",
      "text": "Hide my true feelings about the conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q30", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "hiding_emotions", "category": "conflict_behavior",
      "text": "Conceal how the conflict is affecting me emotionally.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q31", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "self_criticizing", "category": "conflict_behavior",
      "text": "Blame myself when a conflict does not go well.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } },

    { "id": "q32", "type": "scale", "subscale": "passive_destructive",
      "behavior_temperature": "cool", "behavior_cluster": "self_criticizing", "category": "conflict_behavior",
      "text": "Dwell on my own mistakes in handling a conflict.",
      "scale_range": { "min": 1, "max": 6, "labels": { "1": "Never", "2": "Rarely", "3": "Seldom", "4": "Often", "5": "Frequently", "6": "Always" } } }
  ]
}
