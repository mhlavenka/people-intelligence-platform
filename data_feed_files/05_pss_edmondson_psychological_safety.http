{
  "moduleType": "conflict",
  "instrumentId": "PSS-Edmondson",
  "instrumentVersion": "1999",
  "title": "Psychological Safety Scale (Edmondson, 1999)",
  "description": "Measures the shared team belief that interpersonal risk-taking is safe — that members will not be punished or humiliated for speaking up, disagreeing, or making mistakes. The single strongest predictor of productive conflict in teams (Google Project Aristotle, 2015). Psychometric alpha = .82.",
  "level_of_analysis": "team",
  "rater_type": "self",
  "single_construct": true,
  "aggregation_method": "team_mean",
  "minimum_respondents_per_team": 3,
  "scoring": {
    "method": "normative",
    "subscales": ["psychological_safety"],
    "score_range_per_subscale": { "min": 1, "max": 7 },
    "reverse_scored_items": ["q1", "q3", "q5"],
    "benchmarks": {
      "low": {
        "range": [1.0, 3.5],
        "label": "Psychologically unsafe",
        "interpretation": "Members are unlikely to voice concerns, admit errors, or engage in productive task conflict. High risk of groupthink and suppressed conflict escalation."
      },
      "moderate": {
        "range": [3.6, 5.2],
        "label": "Moderately safe",
        "interpretation": "Some members feel safe; others may not. Conflict is likely inconsistently productive. Leaders should actively model vulnerability and non-punitive responses to disagreement."
      },
      "high": {
        "range": [5.3, 7.0],
        "label": "Psychologically safe",
        "interpretation": "Team is well-positioned for productive task conflict and learning. Risk-taking and candid feedback are normalized. Monitor to ensure safety does not suppress necessary challenge."
      }
    }
  },
  "instructions": "Please indicate the extent to which you agree or disagree with each of the following statements about your immediate work team. 1 = Strongly Disagree, 7 = Strongly Agree.",
  "questions": [
    {
      "id": "q1",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "If you make a mistake on this team, it is often held against you.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q2",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "Members of this team are able to bring up problems and tough issues.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q3",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "People on this team sometimes reject others for being different.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q4",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "It is safe to take a risk on this team.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q5",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "It is difficult to ask other members of this team for help.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q6",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "No one on this team would deliberately act in a way that undermines my efforts.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    },
    {
      "id": "q7",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "Working with members of this team, my unique skills and talents are valued and utilized.",
      "scale_range": {
        "min": 1, "max": 7,
        "labels": { "1": "Strongly Disagree", "2": "Disagree", "3": "Somewhat Disagree", "4": "Neither Agree nor Disagree", "5": "Somewhat Agree", "6": "Agree", "7": "Strongly Agree" }
      }
    }
  ]
}
