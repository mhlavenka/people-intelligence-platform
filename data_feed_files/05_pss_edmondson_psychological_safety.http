{
  "moduleType": "conflict",
  "instrumentId": "PSS-Edmondson",
  "instrumentVersion": "1999",
  "title": "Psychological Safety Scale (Edmondson, 1999)",
  "description": "Measures the shared team belief that interpersonal risk-taking is safe — specifically, that members will not be punished or humiliated for speaking up, disagreeing, or making mistakes. Psychological safety is the single strongest predictor of productive conflict in teams (Google Project Aristotle, 2015). Psychometric alpha = .82 in original validation.",
  "level_of_analysis": "team",
  "aggregation_method": "team_mean",
  "minimum_respondents_per_team": 3,
  "single_construct": true,
  "scoring": {
    "method": "normative",
    "unit": "team_aggregate",
    "reverse_score_formula": "max_plus_one_minus_raw",
    "reverse_scored_items": ["q1", "q2", "q6"],
    "score_range": { "min": 1, "max": 7 },
    "team_score_calculation": "mean_of_all_7_items_after_reverse_scoring",
    "benchmarks": {
      "low":      { "range": [1.0, 3.5], "label": "Psychologically unsafe", "interpretation": "Members are unlikely to voice concerns, admit errors, or engage in productive task conflict. High risk of groupthink and suppressed conflict escalation." },
      "moderate": { "range": [3.6, 5.2], "label": "Moderately safe", "interpretation": "Some members feel safe; others may not. Conflict is likely inconsistently productive. Leaders should actively model vulnerability and non-punitive responses to disagreement." },
      "high":     { "range": [5.3, 7.0], "label": "Psychologically safe", "interpretation": "Team is well-positioned for productive task conflict and learning. Risk-taking and candid feedback are normalized. Monitor to ensure safety does not suppress necessary challenge." }
    }
  },
  "scale_range": {
    "min": 1,
    "max": 7,
    "labels": {
      "1": "Strongly Disagree",
      "2": "Disagree",
      "3": "Somewhat Disagree",
      "4": "Neither Agree nor Disagree",
      "5": "Somewhat Agree",
      "6": "Agree",
      "7": "Strongly Agree"
    }
  },
  "instructions": "Please indicate the extent to which you agree or disagree with each of the following statements about your immediate work team.",
  "questions": [

    {
      "id": "q1",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "If you make a mistake on this team, it is often held against you.",
      "scoring_note": "REVERSE SCORED: High agreement (7) indicates LOW safety. Raw 7 → scored 1.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q2",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "Members of this team are able to bring up problems and tough issues.",
      "scoring_note": "FORWARD SCORED — note: some published versions list this as reverse. Use original Edmondson (1999) coding where higher agreement = higher safety.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q3",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "People on this team sometimes reject others for being different.",
      "scoring_note": "REVERSE SCORED: High agreement = LOW safety.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q4",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "It is safe to take a risk on this team.",
      "scoring_note": "FORWARD SCORED: Higher agreement = higher safety.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q5",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "It is difficult to ask other members of this team for help.",
      "scoring_note": "REVERSE SCORED: High agreement = LOW safety.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q6",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": true,
      "reverse_score_formula": "max_plus_one_minus_raw",
      "text": "No one on this team would deliberately act in a way that undermines my efforts.",
      "scoring_note": "FORWARD SCORED: Higher agreement = higher safety.",
      "scale_range": { "min": 1, "max": 7 }
    },

    {
      "id": "q7",
      "type": "scale",
      "subscale": "psychological_safety",
      "category": "psychological_safety",
      "reverse_scored": false,
      "text": "Working with members of this team, my unique skills and talents are valued and utilized.",
      "scoring_note": "FORWARD SCORED: Higher agreement = higher safety.",
      "scale_range": { "min": 1, "max": 7 }
    }
  ]
}
