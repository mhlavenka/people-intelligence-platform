# App
NODE_ENV=development
PORT=3030
FRONTEND_URL=http://localhost:4200

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/artes

# JWT
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic
ANTHROPIC_API_KEY=your-key-here

# AWS
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=artes-assets
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar Integration (per-coach OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/api/calendar/auth/google/callback
