{
  "name": "artes-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "seed:admin": "ts-node --project tsconfig.json src/scripts/seed-admin.ts",
    "seed:surveys": "ts-node --project tsconfig.json src/scripts/seed-surveys.ts",
    "seed:plans": "ts-node --project tsconfig.json src/scripts/seed-plans.ts",
    "backfill:isCoachee": "ts-node --project tsconfig.json src/scripts/backfill-isCoachee.ts",
    "deploy": "npm run build && pm2 restart ecosystem.config.js --env production"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/client-ses": "^3.1020.0",
    "@azure/msal-node": "^5.1.3",
    "@googleapis/calendar": "^14.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@simplewebauthn/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-holidays": "^3.27.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ical-generator": "^10.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.14",
    "otplib": "^10.2.3",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "stripe": "^21.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
