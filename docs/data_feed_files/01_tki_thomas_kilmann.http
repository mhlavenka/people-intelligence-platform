### Thomas-Kilmann Conflict Mode Instrument (TKI)
### instrumentId: TKI | instrumentVersion: 2007
### level_of_analysis: individual | scoring.method: ipsative
### Changes from v1: no structural changes needed — model now includes modes_contrasted

POST http://localhost:3030/api/surveys/templates
Content-Type: application/json
Authorization: Bearer PASTE_ACCESS_TOKEN_HERE

{
  "moduleType": "conflict",
  "instrumentId": "TKI",
  "instrumentVersion": "2007",
  "title": "Thomas-Kilmann Conflict Mode Instrument (TKI)",
  "description": "Measures an individual's typical behavior in conflict situations across five modes: Competing, Collaborating, Compromising, Avoiding, and Accommodating.",
  "level_of_analysis": "individual",
  "rater_type": "self",
  "scoring": {
    "method": "ipsative",
    "subscales": ["competing", "collaborating", "compromising", "avoiding", "accommodating"],
    "items_per_subscale": 6,
    "total_items": 30,
    "score_range_per_subscale": { "min": 0, "max": 12 },
    "note": "Scores are relative. All subscale scores sum to 30. Do not compare across individuals using parametric statistics."
  },
  "instructions": "Think about situations in which your wishes differ from those of another person. How do you usually respond? For each pair, choose the statement (A or B) most characteristic of your behavior.",
  "questions": [
    {
      "id": "q1", "pair_id": 1, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a conflict arises, how do you typically handle responsibility for resolving it?",
      "modes_contrasted": ["accommodating", "avoiding"],
      "options": [
        { "value": "A", "text": "There are times when I let others take responsibility for solving the problem.", "subscale": "accommodating" },
        { "value": "B", "text": "Rather than negotiate the things on which we disagree, I try to stress those things upon which we both agree.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q2", "pair_id": 2, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When working through a disagreement, how far do you go to find a solution?",
      "modes_contrasted": ["compromising", "collaborating"],
      "options": [
        { "value": "A", "text": "I try to find a compromise solution.", "subscale": "compromising" },
        { "value": "B", "text": "I attempt to deal with all of the other person's and my concerns.", "subscale": "collaborating" }
      ]
    },
    {
      "id": "q3", "pair_id": 3, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When pursuing your goals creates friction, which do you prioritize?",
      "modes_contrasted": ["competing", "accommodating"],
      "options": [
        { "value": "A", "text": "I am usually firm in pursuing my goals.", "subscale": "competing" },
        { "value": "B", "text": "I might try to soothe the other's feelings and preserve our relationship.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q4", "pair_id": 4, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When your wishes conflict with another person's, what do you tend to do?",
      "modes_contrasted": ["compromising", "accommodating"],
      "options": [
        { "value": "A", "text": "I try to find a compromise solution.", "subscale": "compromising" },
        { "value": "B", "text": "I sometimes sacrifice my own wishes for the wishes of the other person.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q5", "pair_id": 5, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a disagreement needs to be addressed, which approach fits you better?",
      "modes_contrasted": ["collaborating", "avoiding"],
      "options": [
        { "value": "A", "text": "I consistently seek the other's help in working out a solution.", "subscale": "collaborating" },
        { "value": "B", "text": "I try to do what is necessary to avoid useless tensions.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q6", "pair_id": 6, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a conflict arises, which of the following better describes your instinctive response?",
      "modes_contrasted": ["avoiding", "competing"],
      "options": [
        { "value": "A", "text": "I try to avoid creating unpleasantness for myself.", "subscale": "avoiding" },
        { "value": "B", "text": "I try to win my position.", "subscale": "competing" }
      ]
    },
    {
      "id": "q7", "pair_id": 7, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When you are not ready to engage a conflict directly, what do you typically do?",
      "modes_contrasted": ["avoiding", "compromising"],
      "options": [
        { "value": "A", "text": "I try to postpone the issue until I have had some time to think it over.", "subscale": "avoiding" },
        { "value": "B", "text": "I give up some points in exchange for others.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q8", "pair_id": 8, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When you have a strong position in a disagreement, which best reflects how you act?",
      "modes_contrasted": ["competing", "collaborating"],
      "options": [
        { "value": "A", "text": "I am usually firm in pursuing my goals.", "subscale": "competing" },
        { "value": "B", "text": "I attempt to get all concerns and issues immediately out in the open.", "subscale": "collaborating" }
      ]
    },
    {
      "id": "q9", "pair_id": 9, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When you find yourself in disagreement, how much do you choose to engage?",
      "modes_contrasted": ["avoiding", "competing"],
      "options": [
        { "value": "A", "text": "I feel that differences are not always worth worrying about.", "subscale": "avoiding" },
        { "value": "B", "text": "I make some effort to get my way.", "subscale": "competing" }
      ]
    },
    {
      "id": "q10", "pair_id": 10, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When resolving a disagreement, which approach do you tend to use?",
      "modes_contrasted": ["competing", "compromising"],
      "options": [
        { "value": "A", "text": "I am firm in pursuing my goals.", "subscale": "competing" },
        { "value": "B", "text": "I try to find a compromise solution.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q11", "pair_id": 11, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When resolving conflict, how do you balance addressing concerns versus preserving feelings?",
      "modes_contrasted": ["collaborating", "accommodating"],
      "options": [
        { "value": "A", "text": "I attempt to get all concerns and issues immediately out in the open.", "subscale": "collaborating" },
        { "value": "B", "text": "I might try to soothe the other's feelings and preserve our relationship.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q12", "pair_id": 12, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When navigating a contentious point, which statement better fits your behavior?",
      "modes_contrasted": ["avoiding", "compromising"],
      "options": [
        { "value": "A", "text": "I sometimes avoid taking positions which would create controversy.", "subscale": "avoiding" },
        { "value": "B", "text": "I will let the other person have some of what they want if they let me have some of what I want.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q13", "pair_id": 13, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When you need to move a disagreement toward resolution, what do you do?",
      "modes_contrasted": ["compromising", "competing"],
      "options": [
        { "value": "A", "text": "I propose a middle ground.", "subscale": "compromising" },
        { "value": "B", "text": "I press to get my points made.", "subscale": "competing" }
      ]
    },
    {
      "id": "q14", "pair_id": 14, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When sharing your view in a conflict, which approach better describes how you engage?",
      "modes_contrasted": ["collaborating", "competing"],
      "options": [
        { "value": "A", "text": "I tell the other person my ideas and ask for theirs.", "subscale": "collaborating" },
        { "value": "B", "text": "I try to show the other person the logic and benefits of my position.", "subscale": "competing" }
      ]
    },
    {
      "id": "q15", "pair_id": 15, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When managing the tension in a difficult conversation, which fits you better?",
      "modes_contrasted": ["accommodating", "avoiding"],
      "options": [
        { "value": "A", "text": "I might try to soothe the other's feelings and preserve our relationship.", "subscale": "accommodating" },
        { "value": "B", "text": "I try to do what is necessary to avoid tensions.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q16", "pair_id": 16, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When you are asserting yourself in a disagreement, which best reflects your style?",
      "modes_contrasted": ["accommodating", "competing"],
      "options": [
        { "value": "A", "text": "I try not to hurt the other's feelings.", "subscale": "accommodating" },
        { "value": "B", "text": "I try to convince the other person of the merits of my position.", "subscale": "competing" }
      ]
    },
    {
      "id": "q17", "pair_id": 17, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a conflict is uncomfortable, how do you typically respond?",
      "modes_contrasted": ["competing", "avoiding"],
      "options": [
        { "value": "A", "text": "I am usually firm in pursuing my goals.", "subscale": "competing" },
        { "value": "B", "text": "I try to do what is necessary to avoid useless tensions.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q18", "pair_id": 18, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When the other person has a strong preference, how do you handle it?",
      "modes_contrasted": ["accommodating", "compromising"],
      "options": [
        { "value": "A", "text": "If it makes the other person happy, I might let them maintain their views.", "subscale": "accommodating" },
        { "value": "B", "text": "I will let the other person have some of what they want if they let me have some of what I want.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q19", "pair_id": 19, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a conflict has developed, which better describes how you respond to it?",
      "modes_contrasted": ["collaborating", "avoiding"],
      "options": [
        { "value": "A", "text": "I attempt to get all concerns and issues immediately out in the open.", "subscale": "collaborating" },
        { "value": "B", "text": "I try to postpone the issue until I have had some time to think it over.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q20", "pair_id": 20, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When working through a conflict, how do you approach the resolution process?",
      "modes_contrasted": ["collaborating", "compromising"],
      "options": [
        { "value": "A", "text": "I attempt to immediately work through our differences.", "subscale": "collaborating" },
        { "value": "B", "text": "I try to find a fair combination of gains and losses for both of us.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q21", "pair_id": 21, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When entering a difficult conversation, which statement better reflects your mindset?",
      "modes_contrasted": ["accommodating", "collaborating"],
      "options": [
        { "value": "A", "text": "In approaching negotiations, I try to be considerate of the other person's wishes.", "subscale": "accommodating" },
        { "value": "B", "text": "I always lean toward a direct discussion of the problem.", "subscale": "collaborating" }
      ]
    },
    {
      "id": "q22", "pair_id": 22, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When managing a disagreement, which better describes your typical stance?",
      "modes_contrasted": ["compromising", "competing"],
      "options": [
        { "value": "A", "text": "I try to find a position that is intermediate between the other person's and mine.", "subscale": "compromising" },
        { "value": "B", "text": "I assert my wishes.", "subscale": "competing" }
      ]
    },
    {
      "id": "q23", "pair_id": 23, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When thinking about how to handle a conflict, which outcome matters more to you?",
      "modes_contrasted": ["collaborating", "accommodating"],
      "options": [
        { "value": "A", "text": "I am very often concerned with satisfying all our wishes.", "subscale": "collaborating" },
        { "value": "B", "text": "There are times when I let others take responsibility for solving the problem.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q24", "pair_id": 24, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When the other person's position is important to them, how do you respond?",
      "modes_contrasted": ["accommodating", "compromising"],
      "options": [
        { "value": "A", "text": "If the other's position seems very important to them, I would try to meet their wishes.", "subscale": "accommodating" },
        { "value": "B", "text": "I try to get the other person to settle for a compromise.", "subscale": "compromising" }
      ]
    },
    {
      "id": "q25", "pair_id": 25, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When making your case to the other person, which approach better describes you?",
      "modes_contrasted": ["competing", "accommodating"],
      "options": [
        { "value": "A", "text": "I try to show the other person the logic and benefits of my position.", "subscale": "competing" },
        { "value": "B", "text": "In approaching negotiations, I try to be considerate of the other person's wishes.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q26", "pair_id": 26, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When looking for a resolution, how fully do you try to meet both parties' needs?",
      "modes_contrasted": ["compromising", "collaborating"],
      "options": [
        { "value": "A", "text": "I propose a middle ground.", "subscale": "compromising" },
        { "value": "B", "text": "I am nearly always concerned with satisfying all our wishes.", "subscale": "collaborating" }
      ]
    },
    {
      "id": "q27", "pair_id": 27, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When navigating tension with another person, how do you tend to handle it?",
      "modes_contrasted": ["avoiding", "accommodating"],
      "options": [
        { "value": "A", "text": "I sometimes avoid taking positions that would create controversy.", "subscale": "avoiding" },
        { "value": "B", "text": "If it makes the other person happy, I might let them maintain their views.", "subscale": "accommodating" }
      ]
    },
    {
      "id": "q28", "pair_id": 28, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When a conflict needs to be resolved, do you act independently or involve the other person?",
      "modes_contrasted": ["competing", "collaborating"],
      "options": [
        { "value": "A", "text": "I am usually firm in pursuing my goals.", "subscale": "competing" },
        { "value": "B", "text": "I usually seek the other's help in working out a solution.", "subscale": "collaborating" }
      ]
    },
    {
      "id": "q29", "pair_id": 29, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When facing a point of disagreement, which better describes your tendency?",
      "modes_contrasted": ["compromising", "avoiding"],
      "options": [
        { "value": "A", "text": "I propose a middle ground.", "subscale": "compromising" },
        { "value": "B", "text": "I feel that differences are not always worth worrying about.", "subscale": "avoiding" }
      ]
    },
    {
      "id": "q30", "pair_id": 30, "type": "forced_choice", "category": "conflict_mode",
      "scale_descriptor": "forced_choice_dyad",
      "text": "When closing out a disagreement, which approach better describes what you do?",
      "modes_contrasted": ["accommodating", "collaborating"],
      "options": [
        { "value": "A", "text": "I try not to hurt the other's feelings.", "subscale": "accommodating" },
        { "value": "B", "text": "I always share the problem with the other person so that we can work it out.", "subscale": "collaborating" }
      ]
    }
  ]
}
