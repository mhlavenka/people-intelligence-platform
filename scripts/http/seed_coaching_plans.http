### ============================================================
### COACHING PLANS (sortOrder 60–63)
### ============================================================

### COACH-01: Coaching Starter ($99/mo, 5 coachees)
POST {{baseUrl}}/plans
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "key": "coaching-starter",
  "name": "Coaching — Starter",
  "description": "For individual coaches getting started. Session management, action tracking, IDP generation, and basic reporting.",
  "priceMonthly": 9900,
  "overagePriceCents": 0,
  "maxUsers": 5,
  "modules": ["coaching"],
  "limits": {
    "maxAIAnalyses": 10,
    "maxSurveyResponses": 50,
    "maxCoachingSessions": 0,
    "maxFileStorageMB": 500
  },
  "features": [
    "Up to 5 coachees",
    "Coaching engagement management",
    "Session notes (private + shared)",
    "10 AI analyses per month",
    "GROW model IDP generation",
    "Milestone tracking",
    "Coaching journal",
    "Email support"
  ],
  "isActive": true,
  "sortOrder": 60
}

